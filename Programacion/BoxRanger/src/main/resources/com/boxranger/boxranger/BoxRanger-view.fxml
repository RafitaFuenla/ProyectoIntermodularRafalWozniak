<?xml version="1.0" encoding="UTF-8"?>

<!-- Vista principal del menú de BoxRanger -->
<!-- Controlador: BoxRangerController -->
<!-- Pantalla de navegación principal con botones para acceder a cada sección -->

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="540.0"
            prefWidth="400.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.boxranger.boxranger.BoxRangerController">

    <!-- Zona central: logo y botones de navegación -->
    <center>
        <VBox alignment="TOP_CENTER" prefHeight="540.0" prefWidth="400.0" spacing="25.0"
              style="-fx-background-color: #18310e; -fx-border-color: black;" BorderPane.alignment="CENTER">
            <children>

                <!-- Logo principal de BoxRanger -->
                <ImageView fitHeight="87.0" fitWidth="332.0" pickOnBounds="true">
                    <image>
                        <Image url="@img/logoPrincipal.png"/>
                    </image>
                </ImageView>

                <!-- Botón de navegación a la sección de Socios -->
                <Button fx:id="btnSocios" contentDisplay="TOP" maxHeight="-Infinity" maxWidth="-Infinity"
                        mnemonicParsing="false" onAction="#abrirSocios" prefHeight="18.0" prefWidth="176.0"
                        style="-fx-background-color: transparent; -fx-padding: 0;" textAlignment="CENTER"
                        textFill="#e1ff00">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                    <VBox.margin>
                        <Insets/>
                    </VBox.margin>
                    <graphic>
                        <ImageView fitHeight="35.0" fitWidth="169.0" pickOnBounds="true">
                            <image>
                                <Image url="@img/buttonSocios.png"/>
                            </image>
                            <cursor>
                                <Cursor fx:constant="HAND"/>
                            </cursor>
                        </ImageView>
                    </graphic>
                </Button>

                <!-- Botón de navegación a la sección de Entrenadores -->
                <Button fx:id="btnEntrenadores" contentDisplay="TOP" maxHeight="-Infinity" maxWidth="-Infinity"
                        mnemonicParsing="false" onAction="#abrirEntrenadores" prefHeight="18.0" prefWidth="176.0"
                        style="-fx-background-color: transparent; -fx-padding: 0;" textAlignment="CENTER"
                        textFill="#e1ff00">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                    <graphic>
                        <ImageView fitHeight="35.0" fitWidth="169.0" pickOnBounds="true">
                            <image>
                                <Image url="@img/buttonEntrenadores.png"/>
                            </image>
                            <cursor>
                                <Cursor fx:constant="HAND"/>
                            </cursor>
                        </ImageView>
                    </graphic>
                </Button>

                <!-- Botón de navegación a la sección de Clases -->
                <Button fx:id="btnClases" contentDisplay="TOP" maxHeight="-Infinity" maxWidth="-Infinity"
                        mnemonicParsing="false" onAction="#abrirClases" prefHeight="18.0" prefWidth="176.0"
                        style="-fx-background-color: transparent; -fx-padding: 0;" textAlignment="CENTER"
                        textFill="#e1ff00">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                    <graphic>
                        <ImageView fitHeight="35.0" fitWidth="169.0" pickOnBounds="true">
                            <image>
                                <Image url="@img/buttonClases.png"/>
                            </image>
                            <cursor>
                                <Cursor fx:constant="HAND"/>
                            </cursor>
                        </ImageView>
                    </graphic>
                </Button>

                <!-- Botón de navegación a la sección de Pagos -->
                <Button fx:id="btnPagos" contentDisplay="TOP" maxHeight="-Infinity" maxWidth="-Infinity"
                        mnemonicParsing="false" onAction="#abrirPagos" prefHeight="18.0" prefWidth="176.0"
                        style="-fx-background-color: transparent; -fx-padding: 0;" textAlignment="CENTER"
                        textFill="#e1ff00">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                    <graphic>
                        <ImageView fitHeight="35.0" fitWidth="169.0" pickOnBounds="true">
                            <image>
                                <Image url="@img/buttonPagos.png"/>
                            </image>
                            <cursor>
                                <Cursor fx:constant="HAND"/>
                            </cursor>
                        </ImageView>
                    </graphic>
                </Button>

            </children>
            <padding>
                <Insets top="60.0"/>
            </padding>
        </VBox>
    </center>
</BorderPane>
<?xml version="1.0" encoding="UTF-8"?>

<!-- Vista de la pantalla de visualización de Entrenadores -->
<!-- Controlador: EntrenadoresController -->
<!-- Pantalla de solo lectura: permite consultar los entrenadores del box -->

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="540.0"
            prefWidth="800.0" style="-fx-background-color: #18310e;" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.boxranger.boxranger.controller.EntrenadoresController">

    <top>
        <VBox alignment="TOP_CENTER" prefWidth="800.0" spacing="5.0"
              style="-fx-background-color: #18310e; -fx-border-color: black;" BorderPane.alignment="CENTER">
            <children>
                <ImageView fitHeight="70.0" fitWidth="332.0" pickOnBounds="true">
                    <image>
                        <Image url="@img/logoPrincipal.png"/>
                    </image>
                    <VBox.margin>
                        <Insets top="10.0"/>
                    </VBox.margin>
                </ImageView>
                <ImageView fitHeight="28.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@img/tituloEntrenadores.png"/>
                    </image>
                    <VBox.margin>
                        <Insets bottom="10.0"/>
                    </VBox.margin>
                </ImageView>
            </children>
        </VBox>
    </top>

    <bottom>
        <VBox alignment="CENTER" style="-fx-background-color: #18310e;">
            <children>
                <Button mnemonicParsing="false" onAction="#volverAlMenu" style="-fx-background-color: transparent;">
                    <graphic>
                        <ImageView fitHeight="41.0" fitWidth="178.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@img/buttonHome.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
            </children>
            <padding>
                <Insets bottom="10.0" top="5.0"/>
            </padding>
        </VBox>
    </bottom>

    <center>
        <VBox alignment="TOP_CENTER" maxHeight="1.7976931348623157E308" prefWidth="800.0"
              style="-fx-background-color: #18310e;" BorderPane.alignment="TOP_LEFT">
            <children>
                <TableView fx:id="tablaEntrenadores" prefHeight="350.0" prefWidth="800.0"
                           style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colIdEntrenador" prefWidth="50.0" text="ID"/>
                        <TableColumn fx:id="colNombre" prefWidth="120.0" text="Nombre"/>
                        <TableColumn fx:id="colApellidos" prefWidth="150.0" text="Apellidos"/>
                        <TableColumn fx:id="colEspecialidad" prefWidth="120.0" text="Especialidad"/>
                        <TableColumn fx:id="colDNI" prefWidth="100.0" text="DNI"/>
                        <TableColumn fx:id="colEmail" prefWidth="150.0" text="Email"/>
                        <TableColumn fx:id="colTelefono" prefWidth="110.0" text="Teléfono"/>
                    </columns>
                    <VBox.margin>
                        <Insets left="5.0" right="5.0" top="5.0"/>
                    </VBox.margin>
                </TableView>
            </children>
        </VBox>
    </center>
</BorderPane>